{
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter docs dev",
    "dev:core": "pnpm --filter @heynow/react-spread-sheet-table dev",
    "build": "pnpm --filter @heynow/react-spread-sheet-table build",
    "build:docs": "pnpm --filter docs build",
    "test": "pnpm --filter @heynow/react-spread-sheet-table test",
    "test:e2e": "pnpm --filter docs test:e2e",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.0",
    "lefthook": "^2.1.1",
    "typescript": "^5.7.0"
  }
}
