{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "files": {
    "includes": [
      "packages/*/src/**/*.{ts,tsx,css}",
      "packages/*.{ts,tsx}",
      "packages/*/*.{ts,tsx}",
      "apps/*/src/**/*.{ts,tsx,css}",
      "apps/*/e2e/**/*.ts",
      "apps/*/*.{ts,tsx}"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off",
        "noNoninteractiveTabindex": "off"
      },
      "correctness": {
        "noUnusedImports": "error"
      },
      "style": {
        "useComponentExportOnlyModules": "off"
      }
    },
    "domains": {
      "react": "all"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  }
}
