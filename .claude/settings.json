{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(npx tsc:*)",
      "Bash(pnpm:*)",
      "Bash(openspec:*)",
      "Bash(openspec list:*)",
      "Bash(openspec archive:*)",
      "Bash(openspec validate:*)",
      "Bash(openspec show:*)",
      "Bash(openspec create:*)",
      "Bash(openspec spec:*)",
      "Bash(playwright-cli:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(git push --force)",
      "Bash(gh pr merge)",
      "Bash(gh release create)",
      "Bash(gh repo delete)",
      "Bash(gh repo create)",
      "Bash(npm publish)",
      "Bash(pnpm publish)",
      "Bash(yarn publish)",
      "Read(.env)"
    ]
  }
}
