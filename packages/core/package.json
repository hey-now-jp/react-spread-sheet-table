{
  "name": "@heynow-jp/react-spread-sheet-table",
  "version": "0.1.0",
  "description": "A React spreadsheet table component with sorting, filtering, inline editing, and undo/redo support",
  "type": "module",
  "license": "MIT",
  "author": "Hey Now Inc.",
  "homepage": "https://github.com/hey-now-jp/react-spread-sheet-table#readme",
  "bugs": {
    "url": "https://github.com/hey-now-jp/react-spread-sheet-table/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hey-now-jp/react-spread-sheet-table.git",
    "directory": "packages/core"
  },
  "keywords": [
    "react",
    "spreadsheet",
    "table",
    "editable",
    "inline-editing",
    "datagrid"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./styles.css": "./dist/styles.css"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node -e \"require('fs').copyFileSync('../../LICENSE','LICENSE')\" && pnpm run test && pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.4.0",
    "@dnd-kit/dom": "^0.4.0",
    "@dnd-kit/react": "^0.4.0"
  }
}
